+    async def _handle_audio_transcription(
+        self, request: "web.Request"
+    ) -> "web.Response":
+        """POST /v1/audio/transcriptions — transcribe one bounded audio file."""
+        if not self._api_key:
+            return web.json_response(
+                _openai_error("Authentication is not configured"), status=401
+            )
+        auth_err = self._check_auth(request)
+        if auth_err:
+            return auth_err
+        if not request.content_type.startswith("multipart/"):
+            return web.json_response(
+                _openai_error("Expected multipart/form-data"), status=415
+            )
+        if self._audio_transcription_lock.locked():
+            return web.json_response(
+                _openai_error("Audio transcription is busy"),
+                status=429,
+                headers={"Retry-After": "5"},
+            )
+
+        temp_path = None
+        try:
+            reader = await request.multipart()
+            part = await reader.next()
+            if part is None or part.name != "file" or not part.filename:
+                return web.json_response(
+                    _openai_error("A single audio file is required"), status=400
+                )
+            extension = Path(part.filename).suffix.lower()
+            if extension not in AUDIO_EXTENSIONS:
+                return web.json_response(
+                    _openai_error("Unsupported audio format"), status=400
+                )
+
+            with tempfile.NamedTemporaryFile(
+                prefix="hermes-audio-",
+                suffix=extension,
+                delete=False,
+            ) as handle:
+                temp_path = handle.name
+                os.chmod(temp_path, 0o600)
+                size = 0
+                while True:
+                    chunk = await part.read_chunk(size=64 * 1024)
+                    if not chunk:
+                        break
+                    size += len(chunk)
+                    if size > MAX_AUDIO_BYTES:
+                        return web.json_response(
+                            _openai_error("Audio file is too large"), status=413
+                        )
+                    handle.write(chunk)
+
+            if size == 0:
+                return web.json_response(
+                    _openai_error("Audio file is empty"), status=400
+                )
+            if await reader.next() is not None:
+                return web.json_response(
+                    _openai_error("Only one audio file is accepted"), status=400
+                )
+            if not _valid_audio_signature(temp_path, extension):
+                return web.json_response(
+                    _openai_error("Invalid audio file"), status=400
+                )
+
+            async with self._audio_transcription_lock:
+                from tools.transcription_tools import transcribe_audio
+
+                result = await asyncio.to_thread(transcribe_audio, temp_path)
+            if not isinstance(result, dict) or not result.get("success"):
+                return web.json_response(
+                    _openai_error(
+                        "Audio transcription is unavailable",
+                        err_type="server_error",
+                    ),
+                    status=503,
+                )
+            transcript = str(result.get("transcript", "")).strip()
+            if not transcript:
+                return web.json_response(
+                    _openai_error(
+                        "Audio transcription returned no text",
+                        err_type="server_error",
+                    ),
+                    status=503,
+                )
+            return web.json_response({"text": transcript})
+        except Exception:
+            logger.warning("Audio transcription request failed")
+            return web.json_response(
+                _openai_error(
+                    "Audio transcription is unavailable",
+                    err_type="server_error",
+                ),
+                status=503,
+            )
+        finally:
+            if temp_path:
+                try:
+                    os.unlink(temp_path)
+                except FileNotFoundError:
+                    pass
+
