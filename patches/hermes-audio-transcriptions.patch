+def _valid_audio_signature(path: str, extension: str) -> bool:
+    """Validate the small set of containers accepted by the STT endpoint."""
+    try:
+        with open(path, "rb") as handle:
+            header = handle.read(12)
+    except OSError:
+        return False
+    if extension == ".m4a":
+        return len(header) >= 8 and header[4:8] == b"ftyp"
+    if extension == ".ogg":
+        return header.startswith(b"OggS")
+    if extension == ".aac":
+        return len(header) >= 2 and header[0] == 0xFF and (header[1] & 0xF6) == 0xF0
+    return False
+
